<header class="header border-b border-black/15 sticky top-0 z-999 backdrop-blur-sm transition-all bg-white/80" x-data>
    <div class="main-bar relative">
        <div class="container">

            <div class="navbar flex gap-6 items-stretch p-0 w-full">

                <div class="logo flex m-0 pr-8 py-4">
                    <a href="{{ site.url }}" aria-label="{{ __('Vai alla homepage', 'theme') }}">
                        <img src="{{ settings.header_logo|towebp|resize(200) }}" class="logo-image h-12 xl:h-18 w-auto" width="125" height="72" alt="{{ site.title }}">
                    </a>
                </div>

                {% include "partial/main-menu.twig" %}

                {# Search (boilerplate, desktop) #}
                {% include "partial/search.twig" %}

                {# Language switcher (WPML, desktop) #}
                {% if languages|length > 1 %}
                    <div class="language relative hidden items-center lg:flex" x-data="{ open: false }" @click.outside="open = false">
                        <button class="flex h-10 cursor-pointer items-center gap-2 rounded border border-black/15 px-3 text-sm text-neutral-900 hover:border-verde hover:text-verde" @click="open = !open" :aria-expanded="open" aria-haspopup="true" aria-label="{{ __('Seleziona lingua', 'theme') }}" type="button">
                            <i class="fal fa-globe text-base" aria-hidden="true"></i>
                            {{ current_language|upper }}
                            <i class="fal fa-chevron-down text-xs transition-transform duration-200" :class="{ 'rotate-180': open }" aria-hidden="true"></i>
                        </button>

                        <div class="language-menu absolute right-0 top-full z-20 m-0 flex w-max flex-col bg-white text-neutral-900 shadow-lg" x-show="open" x-transition x-cloak role="menu" aria-label="{{ __('Lingue disponibili', 'theme') }}">
                            {% for lang in languages %}
                                <a class="{% if lang.active %}active{% endif %} flex items-center gap-2 p-2 text-sm hover:bg-neutral-100 focus:bg-neutral-100 focus:outline-none" href="{{ lang.url }}" role="menuitem" {% if lang.active %}aria-current="true"{% endif %} @click="open = false">
                                    <span class="block h-2 w-2 rounded-full {{ lang.active ? 'bg-verde' : 'bg-neutral-400' }}"></span>
                                    <img src="{{ lang.country_flag_url }}" alt="" class="w-5 h-4" aria-hidden="true"/>
                                    {{ lang.native_name }}
                                </a>
                            {% endfor %}
                        </div>
                    </div>
                {% endif %}

                {# Mobile: language switcher + menu toggler #}
                <div class="ml-auto flex items-center gap-3 self-center lg:hidden">

                    {% if languages|length > 1 %}
                        <div class="language relative" x-data="{ open: false }" @click.outside="open = false">
                            <button class="flex h-10 cursor-pointer items-center gap-2 rounded border border-black/15 px-4 text-sm text-neutral-900 hover:border-verde hover:text-verde" @click="open = !open" :aria-expanded="open" aria-haspopup="true" aria-label="{{ __('Seleziona lingua', 'theme') }}" type="button">
                                <i class="fal fa-globe text-base" aria-hidden="true"></i>
                                {{ current_language|upper }}
                                <i class="fal fa-chevron-down text-xs transition-transform duration-200" :class="{ 'rotate-180': open }" aria-hidden="true"></i>
                            </button>

                            <div class="language-menu absolute right-0 z-20 mt-1 flex w-max flex-col bg-white text-neutral-900 shadow-lg" x-show="open" x-transition x-cloak role="menu" aria-label="{{ __('Lingue disponibili', 'theme') }}">
                                {% for lang in languages %}
                                    <a class="{% if lang.active %}active{% endif %} flex items-center gap-2 p-2 text-sm hover:bg-neutral-100 focus:bg-neutral-100 focus:outline-none" href="{{ lang.url }}" role="menuitem" {% if lang.active %}aria-current="true"{% endif %} @click="open = false">
                                        <span class="block h-2 w-2 rounded-full {{ lang.active ? 'bg-verde' : 'bg-neutral-400' }}"></span>
                                        <img src="{{ lang.country_flag_url }}" alt="" class="w-5 h-4" aria-hidden="true"/>
                                        {{ lang.native_name }}
                                    </a>
                                {% endfor %}
                            </div>
                        </div>
                    {% endif %}

                    <button class="header-toggler mobile-toggler flex h-10 w-10 flex-shrink-0 cursor-pointer items-center justify-center rounded p-0 text-xl tracking-normal text-white bg-verde hover:bg-verde/80" @click="$dispatch('mobile-menu')" aria-controls="mobile-menu" aria-label="Menu">
                        <i class="fal fa-bars" aria-hidden="true"></i>
                    </button>

                </div>

            </div>
        </div>
    </div>

</header>

{# Mobile Menu #}
{% include 'partial/mobile-menu.twig' %}
