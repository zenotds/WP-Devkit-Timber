{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bizen/section",
	"title": "Sezione",
	"description": "Sezione generica con titolo, sfondo e contenuto libero.",
	"category": "bizen",
	"icon": "align-wide",
	"keywords": ["sezione", "section", "contenuto"],
	"acf": {
		"mode": "preview",
		"renderCallback": "bizen_block_render"
	},
	"supports": {
		"anchor": true,
		"align": ["wide", "full"],
		"jsx": true,
		"mode": true,
		"customClassName": true,
		"color": false
	},
	"example": {
		"attributes": {
			"mode": "preview",
			"data": { "is_example": true }
		}
	},
	"style": "file:./style.css"
}
